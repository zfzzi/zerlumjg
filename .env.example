# OpenAI-compatible Agent, prompt and document routes
OPENAI_API_KEY=
OPENAI_BASE_URL=https://qweapi.com
OPENAI_AGENT_MODEL=gpt-5.5
OPENAI_OUTLINE_MODEL=gpt-5.5

OPENAI_PROMPT_API_KEY=
OPENAI_PROMPT_BASE_URL=https://qweapi.com
OPENAI_PROMPT_MODEL=gpt-5.5

OPENAI_DOCUMENT_OUTPUT_API_KEY=
OPENAI_DOCUMENT_OUTPUT_BASE_URL=https://qweapi.com
OPENAI_DOCUMENT_OUTPUT_MODEL=gpt-image-2

# Optional Ark Agent fallback
ARK_API_KEY=
ARK_AGENT_MODEL=doubao-seed-2-1-pro-260628

# Image generation
IMAGE_GENERATION_PROVIDER=qweapi
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://qweapi.com
OPENAI_IMAGE_MODEL=gpt-image-2

RUNNINGHUB_IMAGE_API_KEY=
RUNNINGHUB_IMAGE_ENDPOINT=https://www.runninghub.ai/openapi/v2/rhart-imagine-image-quality/edit
RUNNINGHUB_UPSCALE_API_KEY=
RUNNINGHUB_UPSCALE_WEBAPP_ID=2074155000317702146
RUNNINGHUB_UPSCALE_APP_PATH=/run/ai-app/2074155000317702146

