      "knowledgeCollections": ["lighting-theory", "standards-audit", "project-cases"]
    },
    "canvas": {
      "defaultAgents": ["lighting-visualization", "scheme-case-research"],
      "knowledgeCollections": ["design-techniques", "visual-references", "project-cases"]
    },
    "video": {
      "defaultAgents": ["lighting-visualization", "scheme-case-research"],
      "knowledgeCollections": ["cultural-tourism", "visual-references", "project-cases"]
    },
    "text": {
      "defaultAgents": ["scheme-case-research", "lighting-foundation"],
      "fallbackRoutes": ["indoor-lighting", "outdoor-landscape-lighting", "road-tunnel-lighting"],
      "knowledgeCollections": ["design-methods", "project-cases", "standards-audit"]
    },
    "fixture": {
      "defaultAgents": ["fixture-compliance"],
      "knowledgeCollections": ["light-sources", "fixture-systems", "product-library"]
    },
    "database": {
      "defaultAgents": ["scheme-case-research"],
      "knowledgeCollections": ["project-cases", "visual-references"]
    },
    "knowledge": {
      "defaultAgents": [
        "lighting-foundation",
        "indoor-lighting",
        "outdoor-landscape-lighting",
        "road-tunnel-lighting",
        "emergency-lighting",
        "fixture-compliance",
        "scheme-case-research",
        "lighting-visualization"
      ],
      "knowledgeCollections": [
        "lighting-theory",
        "light-sources",
        "fixture-systems",
        "design-methods",
        "design-techniques",
        "standards-audit",
        "calculation-tools",
        "product-library",
        "project-cases"
      ]
    },
    "quote": {
      "defaultAgents": ["fixture-compliance"],
      "knowledgeCollections": ["product-library", "project-budgets", "fixture-systems"]
    },
    "hub": {
      "defaultAgents": ["lighting-foundation"],
      "knowledgeCollections": ["project-delivery", "project-cases"]
    }
  },
  "externalSources": {
    "desktopLightingLibrary": {
      "root": "C:\\Users\\43490\\Desktop\\新建文件夹",
      "status": "discovered",
      "importPolicy": "index-first; do not copy raw binaries into repository",
      "collections": {
        "lighting-theory": {
          "patterns": ["01_设计理论基础/**/*.md"],
          "routes": ["lighting-foundation"],
          "trust": "internal-knowledge"
        },
        "light-sources": {
          "patterns": ["02_光源技术/**/*.md"],
          "routes": ["fixture-compliance", "lighting-foundation"],
          "trust": "internal-knowledge"
        },
        "fixture-systems": {
          "patterns": ["03_灯具系统/**/*.md"],
          "routes": ["fixture-compliance"],
          "trust": "internal-knowledge"
        },
        "design-methods": {
          "patterns": ["04_照明设计方法/**/*.md"],
          "routes": [
            "scheme-case-research",
            "indoor-lighting",
            "outdoor-landscape-lighting",
            "road-tunnel-lighting"
          ],
          "trust": "internal-knowledge"
        },
        "design-techniques": {
          "patterns": ["05_设计手法与技巧/**/*.md"],
          "routes": ["lighting-visualization", "scheme-case-research"],
          "trust": "internal-knowledge"
        },
        "standards-audit": {
          "patterns": ["06_标准与规范/**/*.md"],
          "routes": ["lighting-foundation"],
          "trust": "requires-version-audit",
          "needsAudit": true
        },
        "calculation-tools": {
          "patterns": ["07_计算与工具/**/*.md"],
          "routes": ["lighting-foundation"],
          "trust": "internal-knowledge",
          "futureAgent": "lighting-calculation"
        },
        "product-library": {
          "patterns": ["08_产品资料库/**/*.md", "09_项目实践/**/*.xls"],
          "routes": ["fixture-compliance"],
          "trust": "requires-product-audit"
        },
        "project-cases": {
          "patterns": ["09_项目实践/**/*.md", "09_项目实践/**/*.pdf", "09_项目实践/**/*.pptx", "09_项目实践/**/*.ppt"],
          "routes": ["scheme-case-research"],
          "trust": "private-internal-case"
        },
        "visual-references": {
          "patterns": ["09_项目实践/**/*.jpg", "09_项目实践/**/*.png", "09_项目实践/**/*.mp4", "09_项目实践/**/*.wmv"],
          "routes": ["lighting-visualization"],
          "trust": "private-internal-reference"
        },
        "project-delivery": {
          "patterns": ["09_项目实践/09.*.md"],
          "routes": ["lighting-foundation"],
          "trust": "internal-process",
          "futureAgent": "project-delivery"
        }
      }
    }
  },
  "ingestionGuards": {
    "doNotExecute": ["*.py", "*.fas", "*.lsp", "*.scr", "*.bat", "*.cmd", "*.ps1", "*.exe"],
    "quarantineBeforeUse": ["*.zip", "*.rar", "*.7z", "*.dwl", "*.fas"],
    "binaryIndexOnlyInitially": ["*.dwg", "*.wmv", "*.mp4", "*.eqd"],
    "standardsRequireCurrentVersionCheck": true,
    "projectCasesDefaultPrivacy": "private",
    "imagesDefaultUsage": "internal-reference-only"
  }
}
